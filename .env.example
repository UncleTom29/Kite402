# =============================================================================
# Kite402 Environment Variables
# Copy this file to .env and fill in all values before running.
# =============================================================================

# -----------------------------------------------------------------------------
# Kite Chain (Testnet: ChainID 2368 | Mainnet: ChainID 2366)
# -----------------------------------------------------------------------------
KITE_RPC_URL=https://rpc-testnet.gokite.ai
KITE_CHAIN_ID=2368
KITE_BUNDLER_RPC=https://bundler-service.staging.gokite.ai/rpc/
KITE_SETTLEMENT_TOKEN=0x0fF5393387ad2f9f691FD6Fd28e07E3969e27e63
KITE_SETTLEMENT_CONTRACT=0x8d9FaD78d5Ce247aA01C140798B9558fd64a63E3
KITE_VAULT_IMPLEMENTATION=0xB5AAFCC6DD4DFc2B80fb8BCcf406E1a2Fd559e23
KITE_GASLESS_ENDPOINT=https://gasless.gokite.ai

# Mainnet values (populate after mainnet deploy)
KITE_RPC_URL_MAINNET=https://rpc.gokite.ai
KITE_CHAIN_ID_MAINNET=2366
KITE_SETTLEMENT_TOKEN_MAINNET=0x7aB6f3ed87C42eF0aDb67Ed95090f8bF5240149e

# Deployed contract addresses (populate after running deploy scripts)
KITE402_REGISTRY_ADDRESS=
KITE_CARD_ATTESTATION_ADDRESS=
AGENT_VAULT_IMPLEMENTATION_ADDRESS=
MULTISIG_OPERATOR_ADDRESS=
BRIDGE_RECEIVER_ADDRESS=

# Private key for contract deployment & server signing (NEVER commit this)
DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Card Issuance API (Lithic or Marqeta)
# -----------------------------------------------------------------------------
CARD_ISSUER=lithic
CARD_ISSUER_API_KEY=
CARD_ISSUER_BASE_URL=https://sandbox.lithic.com/v1

# Spend approval threshold in USDC cents (e.g. 1000 = $10.00)
CARD_APPROVAL_THRESHOLD_CENTS=1000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://kite402:kite402password@localhost:5432/kite402
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication & Security
# -----------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-random-256-bit-secret
JWT_EXPIRES_IN=7d
WEBHOOK_SECRET=change-me-to-a-random-256-bit-hmac-secret

# -----------------------------------------------------------------------------
# Goldsky Subgraph
# -----------------------------------------------------------------------------
GOLDSKY_API_KEY=
GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_xxx/subgraphs/kite402/v1/gn

# -----------------------------------------------------------------------------
# LayerZero Endpoint Addresses
# -----------------------------------------------------------------------------
LZ_ENDPOINT_ETHEREUM_SEPOLIA=0x...
LZ_ENDPOINT_BASE_SEPOLIA=0x...
LZ_BRIDGE_SENDER_ETHEREUM=
LZ_BRIDGE_SENDER_BASE=

# -----------------------------------------------------------------------------
# Kite Agent Passport
# -----------------------------------------------------------------------------
PASSPORT_SERVICE_NAME=kite402-card-issuance
PASSPORT_WEBHOOK_URL=https://api.kite402.xyz/passport/webhook
KITE_WALLET_ADDRESS=

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
PORT=4000
NODE_ENV=development
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
