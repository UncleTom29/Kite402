{
  "name": "kite402",
  "version": "1.0.0",
  "private": true,
  "description": "Kite-powered wallets for AI agents with instant virtual Visa card issuance via x402",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "pnpm -r run lint",
    "dev": "pnpm --filter @kite402/api dev & pnpm --filter @kite402/web dev",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "contracts:deploy:testnet": "pnpm --filter @kite402/contracts run deploy:testnet",
    "contracts:deploy:mainnet": "pnpm --filter @kite402/contracts run deploy:mainnet",
    "contracts:test": "pnpm --filter @kite402/contracts run test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
