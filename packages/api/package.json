{
  "name": "@kite402/api",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "sh -c 'set -a; . ../../.env; set +a; tsx watch src/server.ts'",
    "start": "node dist/server.js",
    "db:generate": "sh -c 'set -a; . ../../.env; set +a; prisma generate'",
    "db:migrate": "sh -c 'set -a; . ../../.env; set +a; prisma migrate deploy'",
    "db:migrate:dev": "sh -c 'set -a; . ../../.env; set +a; prisma migrate dev'",
    "db:studio": "sh -c 'set -a; . ../../.env; set +a; prisma studio'",
    "test": "jest --runInBand",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@kite402/sdk": "workspace:*",
    "@prisma/client": "^5.13.0",
    "@trpc/server": "^10.45.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.11.0",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "rate-limiter-flexible": "^5.0.0",
    "superjson": "^2.2.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "prisma": "^5.13.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
